# Local development template only. Production secrets must be configured in the hosting secret manager.
APP_ENV=development
APP_DEBUG=false

DB_HOST=localhost
DB_PORT=5432
DB_NAME=atlas_bank
DB_USER=postgres
DB_PASS=
DB_SCHEMA=atlas_bank_schema
DB_SSLMODE=prefer

SESSION_LIFETIME=480
SESSION_NAME=ATLAS_BANK_SESSION

JWT_SECRET=change_me_local_only
JWT_ISSUER=atlas-bank-api
MFA_BYPASS_CODE=
DATA_ENCRYPTION_KEY=atlas_bank_local_development_key_change_me

# Comma-separated exact origins; never use * with credentialed banking sessions.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000
